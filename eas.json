{
  "cli": {
    "version": ">= 16.3.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "API_BASE_URL": "https://inventory-api.bvrdesign.africa/api/v1",
        "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME": "dauv815j5",
        "NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET": "inventory-mgmt-preset"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "API_BASE_URL": "https://inventory-api.bvrdesign.africa/api/v1",
        "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME": "dauv815j5",
        "NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET": "inventory-mgmt-preset"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "API_BASE_URL": "https://inventory-api.bvrdesign.africa/api/v1",
        "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME": "dauv815j5",
        "NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET": "inventory-mgmt-preset"
      }
    },
    "apk": {
      "distribution": "internal",
      "channel": "production",
      "config": ".eas/build/eas-build-apk.yml",
      "env": {
        "API_BASE_URL": "https://inventory-api.bvrdesign.africa/api/v1",
        "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME": "dauv815j5",
        "NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET": "inventory-mgmt-preset"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
